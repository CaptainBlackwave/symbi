{
  "name": "symlink",
  "version": "3.0.0",
  "description": "AI Agent Monetization Engine - Autonomous Automaton with x402 protocol",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:dev": "npx ts-node src/index.ts",
    "dev": "npx ts-node-dev --respawn src/index.ts",
    "typecheck": "tsc --noEmit",
    "automaton": "RUN_MODE=automaton node dist/index.js",
    "hybrid": "RUN_MODE=hybrid node dist/index.js",
    "test": "mocha tests/**/*.test.js --timeout 10000",
    "test:verbose": "mocha tests/**/*.test.js --timeout 10000 --reporter spec",
    "test:coverage": "nyc npm test",
    "test:wallet": "mocha tests/wallet.test.js --timeout 10000",
    "test:constitution": "mocha tests/constitution.test.js --timeout 10000",
    "test:automaton": "mocha tests/automaton.test.js --timeout 10000",
    "test:evolution": "mocha tests/evolution.test.js --timeout 10000",
    "test:sandbox": "mocha tests/sandbox.test.js --timeout 10000",
    "test:replication": "mocha tests/replication.test.js --timeout 10000",
    "test:budget": "mocha tests/budget.test.js --timeout 10000",
    "genesis": "npx ts-node src/genesis-cli.ts",
    "onboard": "npx ts-node src/genesis-cli.ts",
    "symbilink": "npx ts-node src/cli/symbilink.ts",
    "cli": "npx ts-node src/cli/symbilink.ts"
  },
  "bin": {
    "symbilink": "./dist/cli/symbilink.js"
  },
  "keywords": [
    "ai-agents",
    "x402",
    "monetization",
    "bot-network",
    "autonomous",
    "automaton",
    "supervisor",
    "a2a",
    "self-sustaining"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "axios": "^1.13.5",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.9.3",
    "playwright": "^1.40.0",
    "semver": "^7.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.5.4",
    "@types/ws": "^8.18.1",
    "mocha": "^10.8.2",
    "nyc": "^17.1.0",
    "typescript": "^5.9.3"
  }
}
