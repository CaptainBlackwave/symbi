# ============================================
# SymbiLink v2.0 - Environment Configuration
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Wallet for x402 payments
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Initial earnings buffer (optional - starts the bot with existing balance)
INITIAL_EARNINGS=0

# ============================================
# LLM Provider (Anthropic Claude)
# ============================================
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================
# Agent Registry API Keys (Optional)
# ============================================
# These enable discovery from multiple agent networks

# CrewAI - Multi-agent orchestration
CREWAI_API_KEY=

# Databricks - Enterprise ML platform
DATABRICKS_TOKEN=
DATABRICKS_WORKSPACE_URL=

# AutoGen - Microsoft's agent framework
AUTOGEN_API_KEY=

# LangChain - LLM application framework
LANGCHAIN_API_KEY=

# OpenAI - GPT models and Assistants API
OPENAI_API_KEY=

# LlamaIndex - Data framework
LLAMAINDEX_API_KEY=

# ============================================
# Cache Configuration (Optional)
# ============================================
# Redis URL for distributed caching
# If not set, uses in-memory cache
REDIS_URL=

# ============================================
# Budget Configuration
# ============================================
# Maximum spend per hour on LLM/API calls
MAX_HOURLY_SPEND=10

# Minimum reserve before surge pricing activates
MIN_RESERVE=1.00

# ============================================
# Registry Configuration
# ============================================
# How often to refresh agent discovery (ms)
REGISTRY_REFRESH_INTERVAL=300000

# Timeout for registry API calls (ms)
REGISTRY_TIMEOUT=5000

# ============================================
# Logging
# ============================================
LOG_LEVEL=info